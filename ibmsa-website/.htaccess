# ==========================================================
# IBMSA SEO + SECURITY HARDENING
# Apache / shared hosting friendly baseline
# ==========================================================

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host: non-www
RewriteCond %{HTTP_HOST} ^www\.ibmsa\.com\.au$ [NC]
RewriteRule ^ https://ibmsa.com.au%{REQUEST_URI} [L,R=301]

# Retire legacy hacked/spam URL patterns with 410
RewriteRule ^saiga(/.*)?$ - [G,L,NC]
RewriteCond %{THE_REQUEST} \s/+products/ [NC]
RewriteRule ^products/ - [G,L]
RewriteRule ^[0-9]{5,}\.htm$ - [G,L]

# Extensionless internal routing helpers
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^en/([A-Za-z0-9\-_/]+)$ /en/$1.html [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^fr/([A-Za-z0-9\-_/]+)$ /fr/$1.html [L]

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType image/webp "access plus 90 days"
  ExpiresByType image/png "access plus 90 days"
  ExpiresByType image/jpeg "access plus 90 days"
  ExpiresByType image/svg+xml "access plus 90 days"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  Header always set Content-Security-Policy "default-src 'self' https: data: blob:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' https:; img-src 'self' https: data: blob:; font-src 'self' https: data:; connect-src 'self' https:; frame-ancestors 'self'; upgrade-insecure-requests"
</IfModule>

ErrorDocument 404 /404.html
